[Unit]
Description=rusNAS Storage Analyzer — Collector
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/bin/nice -n 19 /usr/bin/ionice -c3 /usr/bin/python3 /usr/share/cockpit/rusnas/scripts/storage-collector.py
User=root
StandardOutput=append:/var/log/rusnas/storage-collector.log
StandardError=append:/var/log/rusnas/storage-collector.log
