{
  "name": "rusnas",
  "version": "1.0.0",
  "description": "> Коммерческая NAS-платформа на базе Debian Linux — альтернатива Synology DSM для SMB-клиентов.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "docs": "bash docs/build-docs.sh",
    "docs:serve": "cd docs && python3 -m mkdocs serve -a 0.0.0.0:8000",
    "docs:deploy": "cd docs && python3 -m mkdocs gh-deploy --force",
    "docs:user": "bash user-docs/build-user-docs.sh",
    "docs:user:serve": "cd user-docs && python3 -m mkdocs serve -a 0.0.0.0:8001",
    "docs:user:deploy": "bash install-user-docs.sh",
    "docs:all": "npm run docs && npm run docs:user"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lozovoyd/RusNAS.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lozovoyd/RusNAS/issues"
  },
  "homepage": "https://github.com/lozovoyd/RusNAS#readme",
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "jsdoc": "^4.0.5",
    "jsdoc-to-markdown": "^9.1.3"
  }
}
