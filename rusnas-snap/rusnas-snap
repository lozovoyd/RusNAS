#!/usr/bin/env python3
"""
rusnas-snap — Btrfs snapshot management CLI for rusNAS.

Usage: rusnas-snap <command> [options]
Run as root (sudo).
"""

import argparse
import json
import logging
import os
import sqlite3
import subprocess
import sys
import time
import uuid
from contextlib import contextmanager
from datetime import datetime, timedelta, timezone

# ── Config ────────────────────────────────────────────────────────────────────

DB_PATH     = "/var/lib/rusnas/snaps.db"
BROWSE_BASE = "/tmp/rusnas-snap-browse"
LOG_PATH    = "/var/log/rusnas/snapshots.log"

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
    handlers=[logging.StreamHandler(sys.stderr)],
)
log = logging.getLogger("rusnas-snap")


# ── DB helpers ────────────────────────────────────────────────────────────────

def get_db() -> sqlite3.Connection:
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    conn = sqlite3.connect(DB_PATH, timeout=5)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA foreign_keys=ON")
    return conn


@contextmanager
def db():
    conn = get_db()
    try:
        yield conn
        conn.commit()
    except Exception:
        conn.rollback()
        raise
    finally:
        conn.close()


def db_retry(fn, *args, retries=3, delay=0.1):
    for i in range(retries):
        try:
            return fn(*args)
        except sqlite3.OperationalError as e:
            if "locked" in str(e) and i < retries - 1:
                time.sleep(delay)
                continue
            raise


# ── Output helpers ────────────────────────────────────────────────────────────

def out_json(data):
    print(json.dumps(data, ensure_ascii=False, indent=2))


def fatal(msg: str, code: int = 1):
    log.error(msg)
    print(json.dumps({"ok": False, "error": msg}), file=sys.stderr)
    sys.exit(code)


def ok_json(data: dict):
    data["ok"] = True
    out_json(data)


def human_bytes(n: int) -> str:
    if n == 0:
        return "0 Б"
    for unit in ("Б", "КБ", "МБ", "ГБ", "ТБ"):
        if n < 1024:
            return f"{n:.1f} {unit}" if unit != "Б" else f"{n} {unit}"
        n /= 1024
    return f"{n:.1f} ПБ"


def now_iso() -> str:
    return datetime.now(timezone.utc).astimezone().isoformat()


# ── Btrfs helpers ─────────────────────────────────────────────────────────────

def btrfs_root(path: str) -> str:
    """Return the Btrfs filesystem root for a given path."""
    # Use findmnt to get the actual mount point of the btrfs volume
    result2 = subprocess.run(
        ["findmnt", "--noheadings", "-o", "TARGET", "--target", path, "-t", "btrfs"],
        capture_output=True, text=True
    )
    root = result2.stdout.strip()
    if not root:
        fatal(f"Не является Btrfs путём: {path}")
    return root


def is_btrfs_subvol(path: str) -> bool:
    r = subprocess.run(
        ["btrfs", "subvolume", "show", path],
        capture_output=True
    )
    return r.returncode == 0


def snap_dir_name(subvol_path: str, vol_root: str) -> str:
    rel = os.path.relpath(subvol_path, vol_root)
    return rel.replace("/", "__")


def get_snap_size(snap_path: str) -> int:
    """Get exclusive size of snapshot using btrfs qgroup (best effort)."""
    try:
        r = subprocess.run(
            ["btrfs", "subvolume", "show", snap_path],
            capture_output=True, text=True
        )
        # Try to parse 'Exclusive size' from output
        for line in r.stdout.splitlines():
            if "Exclusive size" in line:
                parts = line.split()
                # format: "Exclusive size: 142.00MiB"
                size_str = parts[-1]
                return parse_btrfs_size(size_str)
    except Exception:
        pass
    # Fallback: du
    try:
        r = subprocess.run(["du", "-sb", snap_path], capture_output=True, text=True)
        return int(r.stdout.split()[0])
    except Exception:
        return 0


def parse_btrfs_size(s: str) -> int:
    s = s.strip()
    multipliers = {"B": 1, "KiB": 1024, "MiB": 1024**2, "GiB": 1024**3, "TiB": 1024**4}
    for suffix, mult in multipliers.items():
        if s.endswith(suffix):
            try:
                return int(float(s[:-len(suffix)]) * mult)
            except ValueError:
                return 0
    return 0


# ── cmd: init-db ──────────────────────────────────────────────────────────────

def cmd_init_db():
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    with db() as conn:
        conn.executescript("""
            CREATE TABLE IF NOT EXISTS snapshots (
                id          TEXT PRIMARY KEY,
                subvol_path TEXT NOT NULL,
                snap_path   TEXT NOT NULL UNIQUE,
                snap_name   TEXT NOT NULL,
                snap_type   TEXT NOT NULL,
                label       TEXT DEFAULT '',
                created_at  TEXT NOT NULL,
                size_bytes  INTEGER DEFAULT 0,
                locked      INTEGER DEFAULT 0,
                valid       INTEGER DEFAULT 1
            );

            CREATE TABLE IF NOT EXISTS schedules (
                id                TEXT PRIMARY KEY,
                subvol_path       TEXT NOT NULL UNIQUE,
                enabled           INTEGER DEFAULT 1,
                cron_expr         TEXT DEFAULT '0 0 * * *',
                retention_last    INTEGER DEFAULT 10,
                retention_hourly  INTEGER DEFAULT 24,
                retention_daily   INTEGER DEFAULT 14,
                retention_weekly  INTEGER DEFAULT 8,
                retention_monthly INTEGER DEFAULT 6,
                notify_email      INTEGER DEFAULT 1,
                notify_telegram   INTEGER DEFAULT 1,
                updated_at        TEXT NOT NULL
            );

            CREATE TABLE IF NOT EXISTS events (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                event_type  TEXT NOT NULL,
                snap_id     TEXT,
                subvol_path TEXT,
                message     TEXT,
                created_at  TEXT NOT NULL
            );

            CREATE INDEX IF NOT EXISTS idx_snapshots_subvol   ON snapshots(subvol_path);
            CREATE INDEX IF NOT EXISTS idx_snapshots_created  ON snapshots(created_at);
            CREATE INDEX IF NOT EXISTS idx_events_created     ON events(created_at);
        """)
    log.info("Database initialised at %s", DB_PATH)
    ok_json({"db_path": DB_PATH})


# ── cmd: create ───────────────────────────────────────────────────────────────

def cmd_create(subvol_path: str, label: str = "", snap_type: str = "manual") -> str:
    subvol_path = os.path.realpath(subvol_path)

    if not is_btrfs_subvol(subvol_path):
        fatal(f"Не является Btrfs subvolume: {subvol_path}")

    vol_root = btrfs_root(subvol_path)
    dir_name = snap_dir_name(subvol_path, vol_root)
    snaps_dir = os.path.join(vol_root, ".snapshots", dir_name)
    os.makedirs(snaps_dir, exist_ok=True)

    ts = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    snap_name = f"@{ts}_{snap_type}"
    snap_path = os.path.join(snaps_dir, snap_name)

    subprocess.run(
        ["btrfs", "subvolume", "snapshot", "-r", subvol_path, snap_path],
        check=True, capture_output=True
    )

    snap_id = str(uuid.uuid4())
    created_at = now_iso()

    with db() as conn:
        conn.execute(
            """INSERT INTO snapshots
               (id, subvol_path, snap_path, snap_name, snap_type, label, created_at, locked, valid)
               VALUES (?,?,?,?,?,?,?,0,1)""",
            (snap_id, subvol_path, snap_path, snap_name, snap_type, label, created_at)
        )
        conn.execute(
            """INSERT INTO events (event_type, snap_id, subvol_path, message, created_at)
               VALUES ('created',?,?,?,?)""",
            (snap_id, subvol_path, f"Создан снапшот {snap_name}" + (f" ({label})" if label else ""), created_at)
        )

    log.info("Snapshot created: %s", snap_path)
    ok_json({"id": snap_id, "snap_path": snap_path, "snap_name": snap_name})
    return snap_id


# ── cmd: list ─────────────────────────────────────────────────────────────────

def cmd_list(subvol_path: str | None = None):
    with db() as conn:
        if subvol_path:
            subvol_path = os.path.realpath(subvol_path)
            rows = conn.execute(
                "SELECT * FROM snapshots WHERE subvol_path=? AND valid=1 ORDER BY created_at DESC",
                (subvol_path,)
            ).fetchall()
        else:
            rows = conn.execute(
                "SELECT * FROM snapshots WHERE valid=1 ORDER BY created_at DESC"
            ).fetchall()

    snaps = []
    total_size = 0
    for r in rows:
        size = r["size_bytes"] or 0
        total_size += size
        snaps.append({
            "id":         r["id"],
            "subvol_path": r["subvol_path"],
            "snap_name":  r["snap_name"],
            "snap_path":  r["snap_path"],
            "snap_type":  r["snap_type"],
            "label":      r["label"] or "",
            "created_at": r["created_at"],
            "size_bytes": size,
            "size_human": human_bytes(size),
            "locked":     bool(r["locked"]),
            "valid":      bool(r["valid"]),
        })

    result = {
        "subvol_path":      subvol_path,
        "snapshots":        snaps,
        "total_count":      len(snaps),
        "total_size_bytes": total_size,
        "total_size_human": human_bytes(total_size),
    }
    out_json(result)


# ── cmd: delete ───────────────────────────────────────────────────────────────

def cmd_delete(snap_id: str, force: bool = False):
    with db() as conn:
        row = conn.execute(
            "SELECT * FROM snapshots WHERE id=?", (snap_id,)
        ).fetchone()
        if not row:
            fatal(f"Снапшот не найден: {snap_id}")
        if row["locked"] and not force:
            fatal("Снапшот заблокирован. Используйте --force для принудительного удаления.")

        snap_path = row["snap_path"]
        if os.path.exists(snap_path):
            subprocess.run(
                ["btrfs", "subvolume", "delete", snap_path],
                check=True, capture_output=True
            )

        conn.execute("UPDATE snapshots SET valid=0 WHERE id=?", (snap_id,))
        conn.execute(
            """INSERT INTO events (event_type, snap_id, subvol_path, message, created_at)
               VALUES ('deleted',?,?,?,?)""",
            (snap_id, row["subvol_path"], f"Удалён снапшот {row['snap_name']}", now_iso())
        )
    log.info("Snapshot deleted: %s", snap_path)
    ok_json({"deleted": snap_id})


