# ── cmd: retention ────────────────────────────────────────────────────────────

def cmd_retention(subvol_path: str):
    subvol_path = os.path.realpath(subvol_path)
    with db() as conn:
        sched = conn.execute(
            "SELECT * FROM schedules WHERE subvol_path=?", (subvol_path,)
        ).fetchone()
        if not sched:
            log.info("No schedule for %s — skipping retention", subvol_path)
            ok_json({"deleted": []})
            return

        snaps = conn.execute(
            "SELECT * FROM snapshots WHERE subvol_path=? AND valid=1 ORDER BY created_at DESC",
            (subvol_path,)
        ).fetchall()

    keep_ids: set[str] = set()

    # Always keep locked
    for s in snaps:
        if s["locked"]:
            keep_ids.add(s["id"])

    # Always keep manual snapshots
    for s in snaps:
        if s["snap_type"] == "manual":
            keep_ids.add(s["id"])

    # Last N
    for s in snaps[:sched["retention_last"]]:
        keep_ids.add(s["id"])

    def pick_one_per_period(period_sec: int, count: int):
        if count == 0:
            return
        cutoff = datetime.now(timezone.utc) - timedelta(seconds=period_sec * count)
        picked: dict[int, str] = {}
        for s in snaps:
            dt = datetime.fromisoformat(s["created_at"])
            if dt.tzinfo is None:
                dt = dt.replace(tzinfo=timezone.utc)
            if dt < cutoff:
                continue
            key = int(dt.timestamp() // period_sec)
            if key not in picked:
                picked[key] = s["id"]
        keep_ids.update(picked.values())

    pick_one_per_period(3600,   sched["retention_hourly"])
    pick_one_per_period(86400,  sched["retention_daily"])
    pick_one_per_period(604800, sched["retention_weekly"])
    pick_one_per_period(2592000, sched["retention_monthly"])

    deleted = []
    for s in snaps:
        if s["id"] in keep_ids:
            continue
        try:
            if os.path.exists(s["snap_path"]):
                r = subprocess.run(
                    ["btrfs", "subvolume", "delete", s["snap_path"]],
                    capture_output=True, timeout=60
                )
                if r.returncode != 0:
                    log.error("btrfs delete failed for %s: %s", s["snap_path"], r.stderr.decode())
                    continue
            with db() as conn:
                conn.execute("UPDATE snapshots SET valid=0 WHERE id=?", (s["id"],))
                conn.execute(
                    """INSERT INTO events (event_type, snap_id, subvol_path, message, created_at)
                       VALUES ('deleted',?,?,?,?)""",
                    (s["id"], subvol_path, f"Retention: удалён {s['snap_name']}", now_iso())
                )
            deleted.append(s["snap_name"])
            log.info("Retention: deleted %s", s["snap_name"])
        except subprocess.TimeoutExpired:
            log.error("Timeout deleting %s", s["snap_path"])
        except Exception as e:
            log.error("Error deleting %s: %s", s["snap_path"], e)

    ok_json({"deleted": deleted, "kept": len(keep_ids)})


# ── cmd: restore ──────────────────────────────────────────────────────────────

def cmd_restore(snap_id: str):
    with db() as conn:
        snap = conn.execute(
            "SELECT * FROM snapshots WHERE id=? AND valid=1", (snap_id,)
        ).fetchone()
    if not snap:
        fatal(f"Снапшот не найден: {snap_id}")

    subvol_path = snap["subvol_path"]
    snap_path   = snap["snap_path"]
    ts          = datetime.now().strftime("%Y%m%d%H%M%S")
    tmp_path    = subvol_path + f".restore_tmp_{ts}"
    backup_path = subvol_path + f".restore_backup_{ts}"

    log.info("Restoring %s from %s", subvol_path, snap["snap_name"])

    # 1. Create writable snapshot from snap_path → tmp
    subprocess.run(
        ["btrfs", "subvolume", "snapshot", snap_path, tmp_path],
        check=True, capture_output=True
    )

    # 2. Move current subvol to backup
    os.rename(subvol_path, backup_path)

    # 3. Move tmp to target
    os.rename(tmp_path, subvol_path)

    # 4. Delete old backup
    subprocess.run(
        ["btrfs", "subvolume", "delete", backup_path],
        check=True, capture_output=True
    )

    with db() as conn:
        conn.execute(
            """INSERT INTO events (event_type, snap_id, subvol_path, message, created_at)
               VALUES ('restored',?,?,?,?)""",
            (snap_id, subvol_path, f"Восстановлено из {snap['snap_name']}", now_iso())
        )

    log.info("Restore complete: %s", subvol_path)
    ok_json({"restored": subvol_path, "from_snap": snap["snap_name"]})


# ── cmd: restore-file ─────────────────────────────────────────────────────────

def cmd_restore_file(snap_id: str, rel_path: str, dest_path: str):
    with db() as conn:
        snap = conn.execute(
            "SELECT * FROM snapshots WHERE id=? AND valid=1", (snap_id,)
        ).fetchone()
    if not snap:
        fatal(f"Снапшот не найден: {snap_id}")

    src = os.path.join(snap["snap_path"], rel_path.lstrip("/"))
    if not os.path.exists(src):
        fatal(f"Файл не найден в снапшоте: {rel_path}")

    os.makedirs(os.path.dirname(os.path.abspath(dest_path)), exist_ok=True)
    subprocess.run(["cp", "-a", src, dest_path], check=True)

    with db() as conn:
        conn.execute(
            """INSERT INTO events (event_type, snap_id, subvol_path, message, created_at)
               VALUES ('restored',?,?,?,?)""",
            (snap_id, snap["subvol_path"],
             f"Восстановлен файл {rel_path} → {dest_path}", now_iso())
        )

    ok_json({"restored_file": dest_path, "from_snap": snap["snap_name"]})


# ── cmd: browse ───────────────────────────────────────────────────────────────

def cmd_browse(snap_id: str):
    with db() as conn:
        snap = conn.execute(
            "SELECT * FROM snapshots WHERE id=? AND valid=1", (snap_id,)
        ).fetchone()
    if not snap:
        fatal(f"Снапшот не найден: {snap_id}")

    mount_point = os.path.join(BROWSE_BASE, snap_id)
    os.makedirs(mount_point, exist_ok=True)

    # Already mounted?
    r = subprocess.run(["findmnt", "-n", mount_point], capture_output=True)
    if r.returncode != 0:
        subprocess.run(
            ["mount", "--bind", "-o", "ro,bind", snap["snap_path"], mount_point],
            check=True
        )
        # Schedule auto-umount in 30 minutes
        subprocess.Popen([
            "systemd-run", "--on-active=1800",
            "/usr/local/bin/rusnas-snap", "browse-umount", snap_id
        ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    ok_json({"mount_path": mount_point, "snap_name": snap["snap_name"]})


def cmd_browse_umount(snap_id: str):
    mount_point = os.path.join(BROWSE_BASE, snap_id)
    if os.path.ismount(mount_point):
        subprocess.run(["umount", mount_point], capture_output=True)
    if os.path.isdir(mount_point):
        try:
            os.rmdir(mount_point)
        except OSError:
            pass
    ok_json({"umounted": mount_point})


# ── cmd: update-sizes ─────────────────────────────────────────────────────────

def cmd_update_sizes(subvol_path: str | None = None):
    with db() as conn:
        if subvol_path:
            subvol_path = os.path.realpath(subvol_path)
            rows = conn.execute(
                "SELECT id, snap_path FROM snapshots WHERE subvol_path=? AND valid=1",
                (subvol_path,)
            ).fetchall()
        else:
            rows = conn.execute(
                "SELECT id, snap_path FROM snapshots WHERE valid=1"
            ).fetchall()

    updated = 0
    for row in rows:
        size = get_snap_size(row["snap_path"])
        with db() as conn:
            conn.execute("UPDATE snapshots SET size_bytes=? WHERE id=?", (size, row["id"]))
        updated += 1

    ok_json({"updated": updated})


# ── cmd: schedule set ─────────────────────────────────────────────────────────

def cmd_schedule_set(subvol_path: str, cron_expr: str, retention_last: int,
                     retention_hourly: int, retention_daily: int,
                     retention_weekly: int, retention_monthly: int,
                     enabled: bool = True,
                     notify_email: bool = True, notify_telegram: bool = True):
    subvol_path = os.path.realpath(subvol_path)
    now = now_iso()
    with db() as conn:
        existing = conn.execute(
            "SELECT id FROM schedules WHERE subvol_path=?", (subvol_path,)
        ).fetchone()
        if existing:
            conn.execute("""
                UPDATE schedules SET
                    enabled=?, cron_expr=?,
                    retention_last=?, retention_hourly=?, retention_daily=?,
                    retention_weekly=?, retention_monthly=?,
                    notify_email=?, notify_telegram=?,
                    updated_at=?
                WHERE subvol_path=?
            """, (int(enabled), cron_expr,
                  retention_last, retention_hourly, retention_daily,
                  retention_weekly, retention_monthly,
                  int(notify_email), int(notify_telegram),
                  now, subvol_path))
        else:
            conn.execute("""
                INSERT INTO schedules
                    (id, subvol_path, enabled, cron_expr,
                     retention_last, retention_hourly, retention_daily,
                     retention_weekly, retention_monthly,
                     notify_email, notify_telegram, updated_at)
                VALUES (?,?,?,?,?,?,?,?,?,?,?,?)
            """, (str(uuid.uuid4()), subvol_path, int(enabled), cron_expr,
                  retention_last, retention_hourly, retention_daily,
                  retention_weekly, retention_monthly,
                  int(notify_email), int(notify_telegram), now))
    ok_json({"subvol_path": subvol_path, "cron_expr": cron_expr})


