# ── cmd: scheduled-run ────────────────────────────────────────────────────────

def cmd_scheduled_run():
    try:
        from croniter import croniter
        has_croniter = True
    except ImportError:
        has_croniter = False
        log.warning("croniter not available — using simple hour-match fallback")

    with db() as conn:
        schedules = conn.execute(
            "SELECT * FROM schedules WHERE enabled=1"
        ).fetchall()

    now = datetime.now()
    created = []
    errors = []

    for sched in schedules:
        subvol_path = sched["subvol_path"]
        try:
            # Check cron expression
            should_run = False
            if has_croniter:
                cron = croniter(sched["cron_expr"], now - timedelta(minutes=5))
                next_run = cron.get_next(datetime)
                should_run = next_run <= now
            else:
                # Simple fallback: match hour and minute from "M H * * *"
                parts = sched["cron_expr"].split()
                if len(parts) == 5:
                    m, h = parts[0], parts[1]
                    should_run = (
                        (m == "*" or int(m) == now.minute) and
                        (h == "*" or int(h) == now.hour)
                    )

            if not should_run:
                continue

            # Check recent snapshot to avoid duplicates
            with db() as conn2:
                last = conn2.execute(
                    """SELECT created_at FROM snapshots WHERE subvol_path=? AND valid=1
                       ORDER BY created_at DESC LIMIT 1""",
                    (subvol_path,)
                ).fetchone()

            if last:
                last_dt = datetime.fromisoformat(last["created_at"])
                if last_dt.tzinfo:
                    last_dt = last_dt.replace(tzinfo=None)
                # Don't create if last snap was within 4 minutes
                if (now - last_dt).total_seconds() < 240:
                    continue

            if not os.path.isdir(subvol_path):
                log.warning("Subvolume not found, skipping: %s", subvol_path)
                continue

            cmd_create(subvol_path, snap_type="scheduled")
            cmd_retention(subvol_path)
            created.append(subvol_path)

        except Exception as e:
            log.error("scheduled-run error for %s: %s", subvol_path, e)
            errors.append({"subvol": subvol_path, "error": str(e)})

    log.info("scheduled-run: created=%d errors=%d", len(created), len(errors))
    ok_json({"created": created, "errors": errors})


# ── cmd: pre-update-all ───────────────────────────────────────────────────────

def cmd_pre_update_all():
    with db() as conn:
        schedules = conn.execute(
            "SELECT subvol_path FROM schedules WHERE enabled=1"
        ).fetchall()

    version = "unknown"
    try:
        r = subprocess.run(
            ["dpkg-query", "-W", "-f=${Version}", "rusnas"],
            capture_output=True, text=True
        )
        version = r.stdout.strip() or "unknown"
    except Exception:
        pass

    results = []
    for sched in schedules:
        subvol_path = sched["subvol_path"]
        if not os.path.isdir(subvol_path):
            continue
        try:
            cmd_create(subvol_path, label=f"pre-update {version}", snap_type="pre_update")
            results.append({"subvol": subvol_path, "ok": True})
        except Exception as e:
            log.error("pre-update-all failed for %s: %s", subvol_path, e)
            results.append({"subvol": subvol_path, "ok": False, "error": str(e)})

    ok_json({"results": results})


# ── cmd: events ───────────────────────────────────────────────────────────────

def cmd_events(limit: int = 50, subvol_path: str | None = None):
    with db() as conn:
        if subvol_path:
            rows = conn.execute(
                """SELECT * FROM events WHERE subvol_path=?
                   ORDER BY created_at DESC LIMIT ?""",
                (subvol_path, limit)
            ).fetchall()
        else:
            rows = conn.execute(
                "SELECT * FROM events ORDER BY created_at DESC LIMIT ?", (limit,)
            ).fetchall()
    ok_json({"events": [dict(r) for r in rows]})


# ── Argument parser ───────────────────────────────────────────────────────────

def build_parser():
    p = argparse.ArgumentParser(
        prog="rusnas-snap",
        description="rusNAS Btrfs snapshot management"
    )
    sub = p.add_subparsers(dest="cmd")

    sub.add_parser("init-db", help="Initialise SQLite database")

    c = sub.add_parser("create", help="Create snapshot")
    c.add_argument("subvol_path")
    c.add_argument("--label", default="")
    c.add_argument("--type", dest="snap_type", default="manual",
                   choices=["manual", "scheduled", "pre_update"])

    l = sub.add_parser("list", help="List snapshots")
    l.add_argument("subvol_path", nargs="?")
    l.add_argument("--json", dest="as_json", action="store_true", default=True)

    d = sub.add_parser("delete", help="Delete snapshot")
    d.add_argument("snap_id")
    d.add_argument("--force", action="store_true")

    lk = sub.add_parser("lock", help="Lock snapshot")
    lk.add_argument("snap_id")

    ul = sub.add_parser("unlock", help="Unlock snapshot")
    ul.add_argument("snap_id")

    lb = sub.add_parser("label", help="Set label")
    lb.add_argument("snap_id")
    lb.add_argument("label_text")

    r = sub.add_parser("retention", help="Apply retention policy")
    r.add_argument("subvol_path")

    rs = sub.add_parser("restore", help="Restore subvolume from snapshot")
    rs.add_argument("snap_id")

    rf = sub.add_parser("restore-file", help="Restore single file from snapshot")
    rf.add_argument("snap_id")
    rf.add_argument("rel_path")
    rf.add_argument("dest_path")

    br = sub.add_parser("browse", help="Mount snapshot read-only for inspection")
    br.add_argument("snap_id")

    bu = sub.add_parser("browse-umount", help="Unmount browsed snapshot")
    bu.add_argument("snap_id")

    us = sub.add_parser("update-sizes", help="Update snapshot size metadata")
    us.add_argument("subvol_path", nargs="?")

    sub.add_parser("scheduled-run", help="Run scheduled snapshots")

    sub.add_parser("pre-update-all", help="Create pre-update snapshots for all volumes")

    # schedule subcommands
    sch = sub.add_parser("schedule", help="Manage schedules")
    sch_sub = sch.add_subparsers(dest="schedule_cmd")

    sch_set = sch_sub.add_parser("set")
    sch_set.add_argument("subvol_path")
    sch_set.add_argument("--cron", default="0 0 * * *")
    sch_set.add_argument("--retention-last",    type=int, default=10)
    sch_set.add_argument("--retention-hourly",  type=int, default=24)
    sch_set.add_argument("--retention-daily",   type=int, default=14)
    sch_set.add_argument("--retention-weekly",  type=int, default=8)
    sch_set.add_argument("--retention-monthly", type=int, default=6)
    sch_set.add_argument("--disabled", action="store_true")
    sch_set.add_argument("--no-email",    action="store_true")
    sch_set.add_argument("--no-telegram", action="store_true")

    sch_get = sch_sub.add_parser("get")
    sch_get.add_argument("subvol_path")

    sch_sub.add_parser("list")

    ev = sub.add_parser("events", help="Show event log")
    ev.add_argument("--limit", type=int, default=50)
    ev.add_argument("--subvol", dest="subvol_path", default=None)

    return p


def main():
    parser = build_parser()
    args = parser.parse_args()

    if args.cmd == "init-db":
        cmd_init_db()

    elif args.cmd == "create":
        cmd_create(args.subvol_path, label=args.label, snap_type=args.snap_type)

    elif args.cmd == "list":
        cmd_list(subvol_path=getattr(args, "subvol_path", None))

    elif args.cmd == "delete":
        cmd_delete(args.snap_id, force=args.force)

    elif args.cmd == "lock":
        cmd_lock(args.snap_id)

    elif args.cmd == "unlock":
        cmd_unlock(args.snap_id)

    elif args.cmd == "label":
        cmd_label(args.snap_id, args.label_text)

    elif args.cmd == "retention":
        cmd_retention(args.subvol_path)

    elif args.cmd == "restore":
        cmd_restore(args.snap_id)

    elif args.cmd == "restore-file":
        cmd_restore_file(args.snap_id, args.rel_path, args.dest_path)

    elif args.cmd == "browse":
        cmd_browse(args.snap_id)

    elif args.cmd == "browse-umount":
        cmd_browse_umount(args.snap_id)

    elif args.cmd == "update-sizes":
        cmd_update_sizes(subvol_path=getattr(args, "subvol_path", None))

    elif args.cmd == "scheduled-run":
        cmd_scheduled_run()

    elif args.cmd == "pre-update-all":
        cmd_pre_update_all()

    elif args.cmd == "events":
        cmd_events(limit=args.limit, subvol_path=args.subvol_path)

    elif args.cmd == "schedule":
        if args.schedule_cmd == "set":
            cmd_schedule_set(
                args.subvol_path,
                cron_expr=args.cron,
                retention_last=args.retention_last,
                retention_hourly=args.retention_hourly,
                retention_daily=args.retention_daily,
                retention_weekly=args.retention_weekly,
                retention_monthly=args.retention_monthly,
                enabled=not args.disabled,
                notify_email=not args.no_email,
                notify_telegram=not args.no_telegram,
            )
        elif args.schedule_cmd == "get":
            cmd_schedule_get(args.subvol_path)
        elif args.schedule_cmd == "list":
            cmd_schedule_list()
        else:
            parser.parse_args(["schedule", "--help"])

    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
