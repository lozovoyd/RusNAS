{
  "id": "rocketchat",
  "name": {"ru": "Rocket.Chat", "en": "Rocket.Chat"},
  "description": {
    "ru": "Корпоративный мессенджер с каналами, видеозвонками и интеграциями",
    "en": "Enterprise team chat with channels, video calls and integrations"
