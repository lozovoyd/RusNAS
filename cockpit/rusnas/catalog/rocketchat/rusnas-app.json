  "min_ram_mb": 1024,
  "disk_gb": 5,
  "containers": 2,
  "featured": false,
  "install_params": [
    {"key": "web_port", "label": "Порт веб-интерфейса", "default": "3000", "type": "port"}
  ],
  "compose_template": "docker-compose.yml"
}
